# Host SSH connection
DEPLOY_HOST=achildrenmile@host-node-01

# Remote directory on the host
REMOTE_DIR=/home/achildrenmile/apps/bandwacht

# Docker container settings
CONTAINER_NAME=bandwacht-web
IMAGE_NAME=bandwacht-web:latest
CONTAINER_PORT=3418:8000

# Public URL for health check
SITE_URL=https://bandwacht.oeradio.at/

# Notification backends (passed into container via docker-compose)
BANDWACHT_NOTIFY_TELEGRAM_BOT_TOKEN=
BANDWACHT_NOTIFY_TELEGRAM_CHAT_ID=
BANDWACHT_NOTIFY_GOTIFY_URL=
BANDWACHT_NOTIFY_GOTIFY_TOKEN=
BANDWACHT_NOTIFY_NTFY_TOPIC=
BANDWACHT_NOTIFY_WEBHOOK_URL=
